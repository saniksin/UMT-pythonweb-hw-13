# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ──────────────────────────────────────────────────────────────────────────────
# Postgres
#   - Локально: POSTGRES_HOST=localhost
#   - У docker-compose: POSTGRES_HOST=postgres (ім'я сервісу)
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=contacts_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Async SQLAlchemy DSN — підставляється з POSTGRES_* змінних
DB_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ──────────────────────────────────────────────────────────────────────────────
# JWT (пара токенів access + refresh)
# ──────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800

# ──────────────────────────────────────────────────────────────────────────────
# Redis (кеш поточного користувача)
#   - Локально: REDIS_HOST=localhost
#   - У docker-compose: REDIS_HOST=redis (ім'я сервісу)
# ──────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_USER_TTL=900

# ──────────────────────────────────────────────────────────────────────────────
# SMTP (FastAPI-Mail, для verification-листів)
# Для Gmail створіть App password: https://myaccount.google.com/apppasswords
# ──────────────────────────────────────────────────────────────────────────────
MAIL_USERNAME=your.account@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your.account@gmail.com
MAIL_PORT=465
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Contacts API
MAIL_STARTTLS=False
MAIL_SSL_TLS=True
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# ──────────────────────────────────────────────────────────────────────────────
# Cloudinary (avatar storage)
# Credentials беруться з https://console.cloudinary.com
# ──────────────────────────────────────────────────────────────────────────────
CLD_NAME=your-cloud-name
CLD_API_KEY=000000000000000
CLD_API_SECRET=your-cloudinary-api-secret

# ──────────────────────────────────────────────────────────────────────────────
# CORS — comma-separated list of allowed origins, або "*" для всього
# ──────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
